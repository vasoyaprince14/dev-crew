{
  "name": "dev-crew",
  "version": "1.0.2",
  "description": "AI-powered developer crew built by Prince Vasoya. Code review, debugging, testing, and more.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dev-crew": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "dev-crew",
    "prince-vasoya",
    "code-review",
    "developer-tools",
    "cli",
    "agents",
    "debugging",
    "testing",
    "security",
    "devops",
    "flutter",
    "react-native",
    "performance",
    "accessibility",
    "multi-provider"
  ],
  "author": "Prince Vasoya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vasoyaprince14/dev-crew.git"
  },
  "bugs": {
    "url": "https://github.com/vasoyaprince14/dev-crew/issues"
  },
  "homepage": "https://github.com/vasoyaprince14/dev-crew#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "diff": "^8.0.3",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
