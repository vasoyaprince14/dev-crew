{
  "name": "dev-crew",
  "version": "1.1.6",
  "description": "AI-powered CLI with 24 agents for code review, debugging, testing, security audit, DevOps, API design, and more. Works with Claude, OpenAI, Copilot, Aider, Ollama.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dev-crew": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "ai-code-review",
    "ai-agents",
    "ai-developer-tools",
