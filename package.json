{
  "name": "dev-crew",
  "version": "1.0.0",
  "description": "Code graph intelligence for AI-assisted development. Blast radius analysis, smart context selection, and 40 specialized agents. Works with Claude Code, Aider, and Ollama.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dev-crew": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "postinstall": "node -e \"try{const c='\\x1b[36m',r='\\x1b[0m',b='\\x1b[1m';console.log();console.log(c+'  ✓ dev-crew installed'+r);console.log('  Run '+b+'npx dev-crew'+r+' to analyze your project');console.log('  Run '+b+'npx dev-crew doctor'+r+' to check AI provider setup');console.log()}catch{}\""
  },
  "keywords": [
    "code-review",
    "code-analysis",
    "ai-agents",
    "developer-tools",
    "cli",
    "static-analysis",
    "code-graph",
    "blast-radius",
    "claude-code",
    "security-audit",
    "test-generator",
    "devops",
    "refactoring",
    "app-builder",
    "code-quality"
  ],
  "author": "Prince Vasoya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vasoyaprince14/dev-crew.git"
  },
  "bugs": {
    "url": "https://github.com/vasoyaprince14/dev-crew/issues"
  },
  "homepage": "https://github.com/vasoyaprince14/dev-crew#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/vasoyaprince14"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "diff": "^8.0.3",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.80.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
