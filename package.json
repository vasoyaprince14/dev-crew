{
  "name": "dev-crew",
  "version": "3.0.1",
  "description": "Build complete apps from a single prompt. AI-powered CLI with 25 agents — app builder, code review, testing, security, DevOps. Works on top of Claude Code, free, no API keys.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dev-crew": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
