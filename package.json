    "static-analysis",
    "linter",
    "debugging",
    "debugger",
    "test-generator",
    "unit-testing",
    "security-audit",
    "vulnerability-scanner",
    "devops",
    "ci-cd",
    "docker",
    "api-design",
    "database",
    "schema-design",
    "refactoring",
    "tech-debt",
    "performance",
    "accessibility",
    "wcag",
    "flutter",
    "react-native",
    "ios",
    "android",
    "mobile",
    "claude",
    "openai",
    "gpt",
    "copilot",
    "ollama",
    "aider",
    "llm",
    "chatgpt",
    "developer-tools",
    "dx",
    "productivity",
    "cli",
    "dev-crew",
    "multi-provider",
    "code-quality",
    "pull-request",
    "pr-review"
  ],
  "author": "Prince Vasoya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vasoyaprince14/dev-crew.git"
  },
  "bugs": {
    "url": "https://github.com/vasoyaprince14/dev-crew/issues"
  },
  "homepage": "https://github.com/vasoyaprince14/dev-crew#readme",
